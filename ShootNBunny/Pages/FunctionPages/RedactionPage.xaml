<Page x:Class="ShootNBunny.Pages.FunctionPages.RedactionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShootNBunny.Pages.FunctionPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RedactionPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>

        <Button x:Name="SaveBtn" VerticalAlignment="Top"
            Height="50" Margin="10 30"
            Content="Сохранить"
            Click="SaveBtn_Click"/>
        

        <TextBox x:Name="BookTextTB" Grid.Column="1"
         Margin="20" Padding="20"
         FontSize="14"/>

        <Button x:Name="CancelBtn" VerticalAlignment="Bottom"
            Height="50" Margin="10 30"
            Content="Назад"
            Click="CancelBtn_Click"/>
        
    </Grid>
</Page>
