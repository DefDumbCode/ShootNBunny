<Page x:Class="ShootNBunny.Pages.FunctionPages.ChangeRolePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShootNBunny.Pages.FunctionPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ChangeRolePage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" >
                <Label Content="Новая роль:"/>
                <ComboBox x:Name="NewRoleCB" Width="200" SelectionChanged="NewRoleCB_SelectionChanged"/>
            </StackPanel>
            <Button x:Name="ConfirmBtn" Height="35" Width="200" Margin="10" Content="Подтвердить" Click="ConfirmBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
