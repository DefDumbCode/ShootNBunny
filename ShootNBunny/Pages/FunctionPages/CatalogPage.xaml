<Page x:Class="ShootNBunny.Pages.FunctionPages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShootNBunny.Pages.FunctionPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox x:Name="BooksLB" MouseDoubleClick="BooksLB_MouseDoubleClick" SelectionChanged="BooksLB_SelectionChanged"
                 Grid.Column="0"
                 Margin="10 15"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="200">
                        <Image Source="{Binding CoverPath}" Width="150" Height="250"/>
                        <TextBlock Text="{Binding BookName}" FontSize="16" TextWrapping="NoWrap"/>
                        <TextBlock Text="{Binding AuthorName}" FontSize="16" TextWrapping="NoWrap"/>
                        <TextBlock Text="{Binding Rate, StringFormat= Рейтинг: {0}}" FontSize="14"/>
                        <TextBlock Text="{Binding ReviewAmnt}" FontSize="14"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Stretch"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
        
        <StackPanel Grid.Column="1">
            <Label Content="Сортировать по:" FontSize="16" Margin="10" Padding="10 0"/>
            <ComboBox x:Name="SortByCB" VerticalContentAlignment="Center"
                  Height="35" Width="125" Margin="5" SelectionChanged="SortByCB_SelectionChanged"/>
            
            <Label Content="Название" FontSize="16" Margin="10" Padding="10 0"/>
            <TextBox x:Name="SearchNameTB" 
                     Width="120" Height="30" Padding="5 0"
                     FontSize="16" 
                     TextChanged="SearchNameTB_TextChanged"/>
            
            <Label Content="Автор" FontSize="16" Margin="10" Padding="10 0"/>
            <TextBox x:Name="SearchAuthorTB" 
                     Width="120" Height="30" Padding="5 0"
                     FontSize="16" 
                     TextChanged="SearchNameTB_TextChanged"/>
            <Label Content="Жанр:" FontSize="16" Margin="10" Padding="10 0"/>
            
            <ComboBox x:Name="GenresCB" VerticalAlignment="Top" 
                      Width="120" Height="35" Margin="10"
                      SelectionChanged="GenresCB_SelectionChanged"/>
        </StackPanel>
        <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
            <Label Content="Статус" FontSize="16" Margin="10"/>
            <ComboBox x:Name="ReadingCB"
          Height="35" Width="150" Margin="20 0 20 20"
                      SelectionChanged="ReadingCB_SelectionChanged"/>
        </StackPanel>
        
    </Grid>
</Page>
