<Page x:Class="ShootNBunny.Pages.FunctionPages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShootNBunny.Pages.FunctionPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="{Binding Name}" HorizontalAlignment="Center"
                       Margin="20 20 20 10"
                       FontSize="20"/>
                <StackPanel Orientation="Horizontal" Margin="20 0">
                    <Label Content="Логин:" FontSize="18"/>
                    <TextBlock Text="{Binding Login}" FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="20 0">
                    <Label Content="Email:" FontSize="18"/>
                    <TextBlock Text="{Binding Email}" FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="20 0">
                    <Label Content="Роль:" FontSize="18"/>
                    <TextBlock Text="{Binding Roles.Name}" FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <Button x:Name="AuthorBtn" Grid.Row="1" HorizontalAlignment="Left" 
                    Width="200"  Height="35" Margin="20"
                    Content="Хочу стать автором"
                    Click="AuthorBtn_Click"/>

            <Label x:Name="FreezeReasonLbl" Grid.Row="2" Content="Вы заморожены! Причины:" Margin="20 0"/>
            <ListBox x:Name="ComplaintsLB" Grid.Column="0" Grid.Row="2" VerticalAlignment="Top"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="20 30 20 20" d:ItemsSource="{d:SampleData ItemCount=5}"
                Padding="10 5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0 0 0 5">
                            <TextBlock x:Name="BookName" Text="{Binding ComplaintObjName}" Margin="0 0 10 0"/>
                                <TextBlock Text="{Binding Reason.Name, StringFormat=Причина: {0}}" Margin="0 0 10 0"/>
                                <Button x:Name="UnfreezeAppBtn" Width="80" Margin="0 5" Content="Обжаловать" HorizontalAlignment="Left"
                                    Click="UnfreezeAppBtn_Click"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        
        <Label Grid.Column="1" VerticalAlignment="Top" 
               Height="30"  Margin="20 20 20 0"
               Content="Ваши отзывы" FontSize="18"/>
        <ListBox x:Name="ReviewsLB" Grid.Column="1"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="10 60 10 20" d:ItemsSource="{d:SampleData ItemCount=5}"
            Padding="10 5">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0 0 0 5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="BookName" Text="{Binding Book.Name}" Margin="0 0 10 0"/>
                            <TextBlock x:Name="ReviewRate" Text="{Binding Rate, StringFormat= Оценка: {0}}"/>
                        </StackPanel>

                        <TextBlock x:Name="ReviewText" Text="{Binding Text}"
                            TextWrapping="Wrap"
                            Margin="0 5 0 0"/>
                        <Button x:Name="UnfreezeReview" HorizontalAlignment="Left" Width="80" Height="30" Click="UnfreezeReview_Click">
                            <TextBlock Text="Оспорить заморозку" TextWrapping="Wrap" FontSize="8"/>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Frozen}"
                                                Value="False">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
