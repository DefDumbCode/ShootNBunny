<Page x:Class="ShootNBunny.Pages.FunctionPages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShootNBunny.Pages.FunctionPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="{Binding Name}" HorizontalAlignment="Center"
                       Margin="20 20 20 10"
                       FontSize="20"/>
                <StackPanel Orientation="Horizontal" Margin="20 0">
                    <Label Content="Логин:" FontSize="18"/>
                    <TextBlock Text="{Binding Login}" FontSize="18"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="20 0">
                    <Label Content="Email:" FontSize="18"/>
                    <TextBlock Text="{Binding Email}" FontSize="18"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="20 0">
                    <Label Content="Роль:" FontSize="18"/>
                    <TextBlock Text="{Binding Roles.Name}" FontSize="18"/>
                </StackPanel>
            </StackPanel>

            <Button x:Name="AuthorBtn" Grid.Row="1" HorizontalAlignment="Left" 
                    Width="200"  Height="35" Margin="20"
                    Content="Хочу стать автором"
                    Click="AuthorBtn_Click"/>

            <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="20">
                <TextBlock Grid.Row="2" Text="{Binding FrozenStatus}" HorizontalAlignment="Left" 
                    Height="35" Width="200" FontSize="20"/>
                <Button x:Name="FreezeComplaintBtn"
                        Height="35" Width="125" Margin="20 0"
                        Content="Оспорить"/>
            </StackPanel>
        </Grid>
        
        <Label Grid.Column="1" VerticalAlignment="Top" 
               Height="30"  Margin="20 20 20 0"
               Content="Ваши отзывы"/>
        <ListBox x:Name="ReviewsLB" Grid.Column="1"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="10 60 10 20" d:ItemsSource="{d:SampleData ItemCount=5}"
            Padding="10 5">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0 0 0 5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ReviewAuthor" Text="{Binding User.Name}" Margin="0 0 10 0"/>
                            <TextBlock x:Name="ReviewRate" Text="{Binding Rate, StringFormat= Оценка: {0}}"/>
                        </StackPanel>

                        <TextBlock x:Name="ReviewText" Text="{Binding Text}"
                            TextWrapping="Wrap"
                            Margin="0 5 0 0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
