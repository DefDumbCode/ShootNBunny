<Page x:Class="ShootNBunny.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShootNBunny.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Авторизация" FontSize="32"/>
            <TextBlock Text="Логин" FontSize="24"/>
            <TextBox x:Name="LoginTB" Height="35"
                     TextChanged="LoginTB_TextChanged"/>
            
            <TextBlock Text="Пароль" FontSize="24"/>
            <TextBox x:Name="PasswordTB" Height="35"
                     TextChanged="LoginTB_TextChanged"/>

            <Button x:Name="AuthBtn" Content="Вход"
                    Height="40" Margin="0 20 0 0"
                    Click="AuthBtn_Click"/>

            <Label x:Name="ToRegBtn" Content="У меня нет аккаунта"
                   HorizontalContentAlignment="Center"
                   FontSize="14"
                   Height="35" Margin="10"
                   MouseDoubleClick="ToRegBtn_Click">
                <Label.Style>
                    <Style TargetType="Label">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="DarkGray"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Label.Style>
            </Label>
        </StackPanel>
    </Grid>
</Page>
