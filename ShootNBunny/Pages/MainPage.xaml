<Page x:Class="ShootNBunny.Pages.FunctionPages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShootNBunny.Pages.FunctionPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <StackPanel Margin="5 10">
                <Button x:Name="BooksCatalogBtn" Height="60" Margin="10"
                            Click="BooksCatalogBtn_Click">
                    <Image Height="50" Width="50" Margin="5" Source="https://cdn-icons-png.flaticon.com/512/3486/3486568.png"/>
                </Button>

                <Button x:Name="BooklistBtn" Height="60" Margin="10"
                            Click="BooklistBtn_Click">
                    <Image Height="50" Width="50" Source="https://cdn-icons-png.freepik.com/256/1027/1027221.png?semt=ais_white_label"/>
                </Button>

                <Button x:Name="RoleBtn" Height="60" Margin="10"
                            Click="RoleBtn_Click">
                    <Image x:Name="RoleImg" Height="50" Width="50" Source="https://cdn-icons-png.flaticon.com/512/7651/7651045.png"/>
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Bottom"
                            Margin="5 0 5 20">
                <TextBlock x:Name="FrozenStatusTB"
                               Margin="0 0 0 10"/>
                <Button x:Name="ProfileBtn" Height="60" Margin="10"
                            Click="ProfileBtn_Click">
                    <Image Height="50" Width="50" Source="https://cdn3.iconfinder.com/data/icons/smoothfill-action/30/action_030-account-user-profile-avatar-512.png"/>
                </Button>
            </StackPanel>

        </Grid>

        <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" Grid.Column="1"/>
    </Grid>
</Page>
