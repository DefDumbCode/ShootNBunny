<Page x:Class="ShootNBunny.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShootNBunny.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegPage">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Регистрация" FontSize="32"/>
            <TextBlock Text="Логин" FontSize="18"/>
            <TextBox x:Name="LoginTB" 
                     Height="30" Margin="0 0 0 10"
                     TextChanged="LoginTB_TextChanged"/>

            <TextBlock Text="Отображаемое имя" FontSize="18"/>
            <TextBox x:Name="NameTB" 
                     Height="30" Margin="0 0 0 10"
                     TextChanged="LoginTB_TextChanged"/>

            <TextBlock Text="Пароль" FontSize="18"/>
            <TextBox x:Name="PasswordTB" 
                     Height="30" Margin="0 0 0 10"
                     TextChanged="LoginTB_TextChanged"/>

            <TextBlock Text="Подтвердите пароль" FontSize="18"/>
            <TextBox x:Name="Password2TB" Height="30"
                     TextChanged="LoginTB_TextChanged"/>

            <Button x:Name="RegBtn" Content="Вход"
                    Height="40" Margin="0 20 0 0"
                    Click="RegBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
